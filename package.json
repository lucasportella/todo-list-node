{
  "name": "todo-list",
  "version": "1.0.0",
  "main": "src/app.ts",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon --conditions=development --exec tsx src/server.ts",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc && cp -r src/database/migrations dist/database/migrations && cp -r src/database/seeds dist/database/seeds"
  },
  "imports": {
    "#app.js": {
      "development": "./src/app.ts",
      "default": "./dist/app.js"
    },
    "#database/*": {
      "development": "./src/database/*.ts",
      "default": "./dist/database/*.js"
    },
    "#repositories/*": {
      "development": "./src/repositories/*.ts",
      "default": "./dist/repositories/*.js"
    },
    "#models/*": {
      "development": "./src/models/*.ts",
      "default": "./dist/models/*.js"
    },
    "#services/*": {
      "development": "./src/services/*.ts",
      "default": "./dist/services/*.js"
    },
    "#controllers/*": {
      "development": "./src/controllers/*.ts",
      "default": "./dist/controllers/*.js"
    },
    "#routes/*": {
      "development": "./src/routes/*.ts",
      "default": "./dist/routes/*.js"
    },
    "#middlewares/*": {
      "development": "./src/middlewares/*.ts",
      "default": "./dist/middlewares/*.js"
    }
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
