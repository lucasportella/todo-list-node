{
  "name": "todo-list",
  "version": "1.0.0",
  "main": "src/app.ts",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon --exec tsx src/server.ts",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc && cp -r src/database/migrations dist/database/migrations && cp -r src/database/seeds dist/database/seeds"
  },
  "imports": {
    "#app.js": "./dist/app.js",
    "#database/*": "./dist/database/*.js",
    "#repositories/*": "./dist/repositories/*.js",
    "#models/*": "./dist/models/*.js",
    "#services/*": "./dist/services/*.js",
    "#controllers/*": "./dist/controllers/*.js",
    "#routes/*": "./dist/routes/*.js",
    "#middlewares/*": "./dist/middlewares/*.js"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "mysql2": "^3.20.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}